# Telegram client API credentials from https://my.telegram.org/apps
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace_with_your_api_hash

# Optional. If omitted, the script asks for it during first login.
TELEGRAM_PHONE=+10000000000

# Local session file path. Keep it private.
TELEGRAM_SESSION=telegram_readonly.session

# OpenAI-compatible LLM API settings.
# For OpenAI Chat Completions-compatible endpoints:
MODEL_API_BASE_URL=https://api.openai.com/v1/chat/completions
MODEL_API_KEY=replace_with_your_model_api_key
MODEL_NAME=gpt-4.1-mini

# Optional: reduce if your provider has a smaller context window.
REPORT_CHUNK_CHARS=18000
